      "id": "a1000001-0001-4001-8001-000000000001",
      "name": "Google Sheets - read series log",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [224, 300],
      "alwaysOutputData": true,
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "sbEr5KyqFvzkdh05",
          "name": "Google Sheets OAuth2 API"
        }
      },
      "notes": "Подключи свой Google Sheets OAuth (id в JSON — пример из другого workflow; при конфликте перепривяжи). Первая строка листа — заголовки. Чтение: последняя строка даёт sora_prompt или topic для продолжения серии."
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all();\nlet previous_prompt = '';\nif (rows.length > 0) {\n  const last = rows[rows.length - 1].json;\n  previous_prompt = String(last.sora_prompt ?? last.topic ?? '').trim();\n}\nconst nextEpisode = rows.length + 1;\n\nconst system = [\n  'You help produce ONE episode of a recurring YouTube Shorts vertical series (9:16). Output MUST use exactly these labels in English, in order, no text before TITLE:.',\n  'TITLE: max 65 characters, click-worthy, matches the episode.',\n  'DESCRIPTION: 2-4 short lines, friendly, one soft CTA (follow for next part), optional #Shorts; you may add one line saying visuals were AI-assisted if appropriate.',\n  'TAGS: exactly 5 to 8 relevant lowercase keywords or short phrases, comma-separated, no #, no duplicates, niche-aligned (no random unrelated words).',\n  'VIDEO_PROMPT: one paragraph only — English Sora-style scene: vertical 9:16, cinematic, strong hook in first second, clear subject and motion, ending on a beat the next episode can continue.',\n  'THUMB_PROMPT: one line — English FLUX image prompt for a vertical cover: bold composition, high contrast, no text/letters in frame, same mood as the episode, eye-catching at small size.',\n  '',\n  'SERIES: If PREVIOUS_VIDEO_PROMPT is non-empty, VIDEO_PROMPT must OPEN as direct continuation of its final beat (same story thread, characters, setting when possible). Otherwise pilot episode with hook.',\n  'CLOSE VIDEO_PROMPT on a transition or micro-cliffhanger. Safe content: no celebrities, brands, gore, adult themes.'\n].join('\\n');\n\nconst user = previous_prompt\n  ? ('Episode number (for your context): ' + nextEpisode + '.\\n\\nPREVIOUS_VIDEO_PROMPT (continue from this ending):\\n\\n' + previous_prompt + '\\n\\nProduce TITLE, DESCRIPTION, TAGS, VIDEO_PROMPT, THUMB_PROMPT for the NEXT episode only.')\n  : ('Episode number: ' + nextEpisode + ' (series premiere). No prior prompt in sheet. Produce TITLE, DESCRIPTION, TAGS, VIDEO_PROMPT, THUMB_PROMPT for episode 1.');\n\nreturn [{ json: {\n  nextEpisode,\n  previous_prompt,\n  deepseekBody: {\n    model: 'deepseek-chat',\n    temperature: 0.85,\n    max_tokens: 1200,\n    messages: [{ role: 'system', content: system }, { role: 'user', content: user }]\n  }\n}}];"
      },
      "id": "a1000001-0001-4001-8001-000000000002",
      "name": "Build series + DeepSeek body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [448, 300],
      "notes": "Считает номер эпизода (число строк + 1) и подставляет последний sora_prompt/topic из листа для продолжения."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.deepseek.com/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "deepSeekApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.deepseekBody) }}",
        "options": {}
      },
      "id": "f058c938-20f6-4d31-b385-0d630cd36d2b",
      "name": "DeepSeek - prompt for Short",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [672, 300],
      "credentials": {
        "deepSeekApi": {
          "id": "mYqtwF9EFcBfzdBq",
          "name": "DeepSeek account 2"
        }
      },
      "notes": "Credential без изменений из твоего workflow (2)."
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.choices?.[0]?.message?.content;\nconst text = String(raw ?? '').trim();\nfunction grab(label) {\n  const re = new RegExp(label + ':\\\\s*([\\\\s\\\\S]*?)(?=\\\\n[A-Z_]+:|$)', 'i');\n  const m = text.match(re);\n  return m ? m[1].trim() : '';\n}\nconst title = grab('TITLE') || 'AI Short';\nconst description = grab('DESCRIPTION') || '';\nconst tags_csv = grab('TAGS') || 'shorts, ai video, vertical';\nconst video_prompt = grab('VIDEO_PROMPT') || text;\nconst thumb_prompt = grab('THUMB_PROMPT') || ('Bold cinematic vertical key art, no text, high contrast, related to: ' + video_prompt.slice(0, 200));\nconst b = $('Build series + DeepSeek body').first().json;\nreturn [{ json: {\n  title,\n  description,\n  tags_csv,\n  video_prompt,\n  thumb_prompt,\n  nextEpisode: b.nextEpisode,\n  raw_deepseek: text\n}}];"
      },
      "id": "a1000001-0001-4001-8001-000000000003",
      "name": "Parse TITLE TAGS VIDEO THUMB",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [896, 300]
