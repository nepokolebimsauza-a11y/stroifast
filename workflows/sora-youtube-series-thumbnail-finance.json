    {
      "parameters": {
        "method": "POST",
        "url": "https://fal.run/fal-ai/flux/schnell",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ prompt: $json.thumb_prompt, num_images: 1, num_inference_steps: 4, enable_safety_checker: true, image_size: 'portrait_4_3', output_format: 'jpeg' }) }}",
        "options": { "timeout": 120000 }
      },
