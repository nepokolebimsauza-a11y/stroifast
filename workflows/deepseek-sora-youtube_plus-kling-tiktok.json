    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.choices?.[0]?.message?.content;\nconst text = String(raw ?? '').trim();\nfunction grab(label) {\n  const re = new RegExp(label + ':\\\\s*([\\\\s\\\\S]*?)(?=\\\\n[A-Z_]+:|$)', 'i');\n  const m = text.match(re);\n  return m ? m[1].trim() : '';\n}\nlet title = grab('TITLE');\nlet description = grab('DESCRIPTION');\nlet video_prompt = grab('VIDEO_PROMPT');\nif (!video_prompt) {\n  video_prompt = text;\n}\nif (!title) {\n  title = 'Learning Friends';\n}\nif (!description) {\n  description = 'A cozy English counting moment for little learners.';\n}\nreturn [{ json: { title, description, video_prompt, raw_deepseek: text } }];"
      },
