      "id": "b2a10001-0001-4001-8001-000000000001",
      "name": "Google Sheets - read kids series log",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [-1008, 520],
      "alwaysOutputData": true,
