# Безопасность Apache (OSPanel). Нужны модули: headers (и при необходимости rewrite).
# При ошибке 500 отключите блоки по очереди и проверьте, что в httpd AllowOverride включает эту папку.

Options -Indexes

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
  # На продакшене с HTTPS раскомментируйте следующую строку (на чистом HTTP локально может мешать):
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Ограничивает XSS, вставку в iframe с других сайтов, лишние источники. Inline script/style нужны текущей вёрстке.
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; script-src 'self' https://cdnjs.cloudflare.com 'unsafe-inline' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://cdnjs.cloudflare.com https://fonts.googleapis.com https://fonts.gstatic.com;"
</IfModule>

# Закрыть доступ к типовым служебным файлам (если они попадут в каталог сайта)
<FilesMatch "^(?:\.env|\.git|composer\.(?:json|lock)|package-lock\.json)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>
